<Window x:Class="CariasWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CariasWPF"
        mc:Ignorable="d"
         Background="BurlyWood"
        Title="MainWindow" Height="650" Width="980">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>


        <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="1"
         FontStyle="Normal" FontWeight="Bold"
         HorizontalContentAlignment="Center"
         FontSize="26"
         Content="PLAYER INFORMATION" FontFamily="Bahnschrift"/>
        <Separator Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" />

        <StackPanel Grid.Row="3" Grid.Column="1"
              Orientation="Vertical"
              x:Name="panelStudentTable">
            <DataGrid x:Name="dataGrid" Height="350"
                AutoGenerateColumns="False"
                SelectionChanged="dataGrid_SelectionChanged"
                Background="Transparent"
                FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Player Name"
                      Binding="{Binding PlayerName}" />
                    <DataGridTextColumn Header="Player Address"
                      Binding="{Binding Address}" />
                    <DataGridTextColumn Header="Team Name"
                      Binding="{Binding TeamName}" />
                    <DataGridTextColumn Header="Total Win"
                                  Binding="{Binding TotalWin}"/>

                </DataGrid.Columns>
            </DataGrid>
            <Button x:Name="btnDeleteData" Content="REMOVE SELECTED PLAYER DETAILS"
              Height="50" FontSize="20"
              FontWeight="Bold"
              IsEnabled="False"
              Cursor="Hand"
              Click="btnDeleteData_Click_1"
              Background="Aqua" RenderTransformOrigin="0.501,1.899"
              />
           
            <Button x:Name="btnClose" Content="CLOSE MENU"
              Height="40"
              FontSize="20"
              FontWeight="UltraBold"
              IsEnabled="False"
              Cursor="Hand"
              Click="btnCloseMenu_Click"
              Background="Aqua"/>
            <Label
             Content="CARIAS, JERALD G."
             FontSize="17"
             Padding="6"
             Background="BurlyWood"
             FontWeight="DemiBold" Height="30" Width="648" RenderTransformOrigin="-0.859,0.563" />
        </StackPanel>

        <Grid Grid.Row="3" Grid.Column="2" Margin="5,10,0,-5" Grid.RowSpan="2" Grid.ColumnSpan="2" RenderTransformOrigin="0.511,0.49">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="110.71"/>
                <RowDefinition Height="197"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0"
             Grid.Column="1"                                     
             Content="Player Details"
             FontWeight="DemiBold"
             HorizontalContentAlignment="Center"
             VerticalContentAlignment="Center"
             Background="BurlyWood"
             FontSize="13" />
            <Label Grid.Row="2"
             Grid.Column="1"
             Content="Player Name"
             FontSize="13"
             Padding="1"
             Background="BurlyWood"
             FontWeight="DemiBold" />
            <TextBox Grid.Row="3"
               x:Name="txtPlayerName"
               Grid.Column="1" 
               Cursor="Hand"
               HorizontalContentAlignment="Left"
               FontSize="14"
               
               BorderThickness="0,0,0,1"
               Padding="2" />
            <Label Grid.Row="5"
             Grid.Column="1"
             Background="BurlyWood"
             Content="Player Address"
             FontSize="13"
             Padding="1"
             
             FontWeight="DemiBold" />
            <TextBox Grid.Row="6"
               x:Name="txtAddress"
               Grid.Column="1" 
               HorizontalContentAlignment="Left"
               FontSize="14"
               BorderThickness="0,0,0,1"
               Padding="2" />
            <Label Grid.Row="7"
             Grid.Column="1"
             Background="BurlyWood"
             Content="Team Name"
             FontSize="13"
             Padding="1"
             FontWeight="DemiBold" Margin="0,5,0,5" Grid.RowSpan="2" RenderTransformOrigin="0.492,0.802"/>
            <ComboBox x:Name="comboboxOrder"
               Grid.Row="8"         
               BorderThickness="0" Margin="0,15,0,5" Grid.RowSpan="2" Grid.Column="1">
                <ComboBoxItem Content="Italy"/>
                <ComboBoxItem Content="Japan"/>
                <ComboBoxItem Content="Philippines"/>
                <ComboBoxItem Content="Germany"/>
                <ComboBoxItem Content="Belgium"/>
                <ComboBoxItem Content="Spain"/>
                <ComboBoxItem Content="USA"/>
                <ComboBoxItem Content="France"/>
                <ComboBoxItem Content="China"/>
                <ComboBoxItem Content="Australia"/>
                <ComboBoxItem Content="Canada"/>
            </ComboBox>


            <Label Grid.Row="13"
             Background="BurlyWood"
             Content="Total Win"
             FontSize="14"
             Padding="1"
             FontWeight="DemiBold" Margin="2,44,0,44" HorizontalAlignment="Left" Width="293" Grid.Column="1" />


            <StackPanel Grid.Row="13"
                  HorizontalAlignment="Left"
                  Background="BurlyWood"
                  Orientation="Horizontal" Margin="-2,67,0,13" Width="325" RenderTransformOrigin="0.5,0.5" Grid.ColumnSpan="3">
                <StackPanel.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="2.221"/>
                        <RotateTransform/>
                        <TranslateTransform X="-0.557"/>
                    </TransformGroup>
                </StackPanel.RenderTransform>
                <RadioButton x:Name="rbOne" Content="1" GroupName="Quantity" Margin="10,0"/>
                <RadioButton x:Name="rbTwo" Content="2" GroupName="Quantity" Margin="10,0"/>
                <RadioButton x:Name="rbThree" Content="3" GroupName="Quantity" Margin="10,0"/>
                <RadioButton x:Name="rbFour" Content="4" GroupName="Quantity" Margin="10,0"/>
                <RadioButton x:Name="rbFive" Content="5" GroupName="Quantity" Margin="10,0"/>
                <RadioButton x:Name="rbSix" Content="6" GroupName="Quantity" Margin="10,0"/>
                <RadioButton x:Name="rbSeven" Content="7" GroupName="Quantity" Margin="10,0"/>
            </StackPanel>
            <Button x:Name="btnSave" Grid.Row="14"
              Content="SAVE" FontSize="20"
              Click="btnSave_Click"
              FontWeight="Bold"
              Margin="2,62,8,75"                  
              Background="Aqua" RenderTransformOrigin="0.508,1.078" Grid.Column="1" Grid.ColumnSpan="2"/>
        </Grid>
    </Grid>
</Window>
